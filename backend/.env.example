# ============================================
# Tourism Platform - Environment Configuration
# ============================================
# Copy this file to .env:
#   cp .env.example .env

# Server Configuration
PORT=5000

# MongoDB Connection
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/tourism-platform
# MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tourism-platform

# JWT Secret (change this to any random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Secret
ADMIN_SECRET=your-admin-registration-secret-key

# File Upload Configuration
UPLOAD_PATH=./src/uploads

# ============================================
# SMTP Email Configuration (OPTIONAL for local)
# ============================================
# The project works fully without email.
# Admin replies are saved in database regardless.
# Only configure this if you WANT replies emailed to visitors.
#
# Gmail setup steps:
#   1. Go to https://myaccount.google.com/security
#   2. Enable "2-Step Verification"
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create an App Password (select "Mail" and "Windows Computer")
#   5. Copy the 16-character password below
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM="Gabon Tourism <your-email@gmail.com>"
