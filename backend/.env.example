# Server Configuration
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/tourism-platform
# OR for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tourism-platform

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Secret (for initial admin registration)
ADMIN_SECRET=your-admin-registration-secret-key

# File Upload Configuration
UPLOAD_PATH=./src/uploads
